# Travel App API — environment template (M23.4)
#
# Copy to `.env` and fill in. NEVER commit a real `.env`. This file contains NO
# secrets — Apple Sign In verification needs only your *public* client id plus
# Apple's *public* keys (fetched at runtime). There is no Apple private key here.
#
# Load it however your host prefers, e.g. locally:
#   set -a; source travel-app/api/.env; set +a
#   node travel-app/api/server.js

# --- Runtime ---------------------------------------------------------------
# 'development' | 'production' | 'test'. In production, apple mode defaults to
# 'jwks' and the insecure 'fake' verifier is refused.
NODE_ENV=development

# Port the HTTP host binds.
PORT=8787

# Public base URL the iPhone app points at (used in logs / future links).
TRAVEL_BASE_URL=http://localhost:8787

# --- Persistence -----------------------------------------------------------
# Durable JSON store directory. Use an ABSOLUTE path on a persistent volume in
# production (NOT an ephemeral container FS). One traveller per store (MVP).
#   e.g. /var/lib/travel-app/data
TRAVEL_STORE_DIR=./.travel-data

# --- Sessions --------------------------------------------------------------
# Session lifetime in hours (default 720 = 30 days).
SESSION_TTL_HOURS=720

# --- Apple Sign In ---------------------------------------------------------
# 'disabled' : sign-in fails closed (no verifier).               [default: dev]
# 'fake'     : deterministic test verifier "apple:<sub>:<email>" (NON-PROD ONLY).
# 'jwks'     : real verification against Apple's public JWKS.     [default: prod]
APPLE_VERIFIER_MODE=disabled

# Required when APPLE_VERIFIER_MODE=jwks. This is your app's bundle id (native
# app) or Services ID (web) registered with Apple — the token `aud`. PUBLIC, not
# a secret.
#   e.g. com.simondodd.travel
APPLE_CLIENT_ID=

# Override only for testing. Defaults to Apple's real issuer.
# APPLE_ISSUER=https://appleid.apple.com
